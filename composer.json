{
  "name": "mtubis/mtcollections",
  "description": "Small PHP collections library (e.g., SortedLinkedList).",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "Mtubis\\MTCollections\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mtubis\\MTCollections\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "scripts": {
    "test": "phpunit",
    "stan": "phpstan analyse",
    "cs:check": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix",
    "qa": [
      "@cs:check",
      "@stan",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}